        "@polkadot/keyring": "^14.0.1",
        "@polkadot/util-crypto": "^14.0.1",
        "commander": "^12.0.0",
        "polkadot-api": "^1.23.3",
        "smoldot": "^2.0.40"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0"
