{
    "name": "cdm",
    "description": "Contract Deployment Manager for pvm smart contracts",
    "version": "0.1.0",
    "type": "module",
    "bin": {
        "cdm": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
