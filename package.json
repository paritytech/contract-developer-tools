        "@dotdm/cdm": "latest",
        "@polkadot-api/descriptors": "file:.papi/descriptors",
        "@polkadot-api/json-rpc-provider": "^0.2.0",
        "@polkadot-labs/hdkd": "^0.0.26",
        "@polkadot-labs/hdkd-helpers": "^0.0.27",
        "polkadot-api": "^1.23.3"
    },
    "devDependencies": {
        "@dotdm/contracts": "^2.0.3",
        "@parity/product-sdk-keys": "^0.2.0",
