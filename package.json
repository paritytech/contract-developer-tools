{
    "name": "contract-developer-tools",
    "version": "0.1.0",
    "type": "module",
    "packageManager": "pnpm@10.17.1",
    "scripts": {
        "postinstall": "papi",
        "start": "bun src/index.ts",
        "setup:local": "bun src/setup-local.ts",
        "deploy:contexts": "bun src/deploy-contexts.ts",
        "test:contexts": "bun src/test-contexts.ts",
        "register:dotns": "bun scripts/register-dotns.ts",
